/**
 * _strcat - concatenates strings
 * @dest: destination string
 * @src: source string
 *
 * Return: Void
 */
void _strcat(char *dest, char *src)
{
int i;
int strlen;
strlen = 0;
while (dest[strlen] != '\0')
{
strlen += 1;
}
for (i = 0; i < strlen; i++)
{
printf("%c", dest[i]);
}
printf("%s\n",src);
}
